generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  STAFF
}

enum CustomerStatus {
  ACTIVE
  CLOSED
  DEFAULTER
}

enum PlanStatus {
  ACTIVE
  CLOSED
  DEFAULTED
}

enum InstallmentStatus {
  PAID
  UNPAID
  PARTIAL
}

enum InvestorStatus {
  ACTIVE
  INACTIVE
}

enum InvestmentTransactionType {
  INVESTOR_DEPOSIT
  PRODUCT_PURCHASE
  INSTALLMENT_COLLECTION
  MANUAL_ADJUSTMENT
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      UserRole @default(STAFF)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Customer {
  id            String         @id @default(cuid())
  name          String
  referenceName String?
  cnic          String         @unique
  mobile        String
  address       String
  photoUrl      String?
  cnicImageUrl  String?
  status        CustomerStatus @default(ACTIVE)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  plans         InstallmentPlan[]

  @@index([name])
  @@index([mobile])
  @@index([status])
}

model Product {
  id               String   @id @default(cuid())
  name             String
  category         String
  purchasePrice    Decimal  @db.Decimal(12, 2)
  cashPrice        Decimal  @db.Decimal(12, 2)
  installmentPrice Decimal  @db.Decimal(12, 2)
  downPayment      Decimal  @db.Decimal(12, 2)
  profit           Decimal  @db.Decimal(12, 2)
  durationMonths   Int
  monthlyAmount    Decimal  @db.Decimal(12, 2)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  plans            InstallmentPlan[]
  investmentTransactions InvestmentTransaction[]

  @@index([name])
  @@index([category])
}

model InstallmentPlan {
  id               String       @id @default(cuid())
  billNumber       Int          @unique @default(autoincrement())
  customerId       String
  customer         Customer     @relation(fields: [customerId], references: [id])
  productId        String
  product          Product      @relation(fields: [productId], references: [id])
  investorId       String?
  investor         Investor?    @relation(fields: [investorId], references: [id], onDelete: SetNull)
  totalAmount      Decimal      @db.Decimal(12, 2)
  downPayment      Decimal      @db.Decimal(12, 2) @default(0)
  remainingBalance Decimal      @db.Decimal(12, 2)
  startDate        DateTime     @default(now())
  status           PlanStatus   @default(ACTIVE)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  installments     Installment[]
  investmentTransactions InvestmentTransaction[]

  @@index([customerId])
  @@index([productId])
  @@index([investorId])
  @@index([status])
}

model Installment {
  id             String            @id @default(cuid())
  planId         String
  plan           InstallmentPlan   @relation(fields: [planId], references: [id], onDelete: Cascade)
  serialNumber   Int
  month          Int
  year           Int
  amount         Decimal           @db.Decimal(12, 2)
  receivedAmount Decimal           @db.Decimal(12, 2) @default(0)
  pendingAmount  Decimal           @db.Decimal(12, 2)
  dueDate        DateTime
  paymentDate    DateTime?
  status         InstallmentStatus @default(UNPAID)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  payments       Payment[]

  @@index([planId])
  @@index([dueDate])
  @@index([status])
}

model Payment {
  id            String      @id @default(cuid())
  installmentId String
  installment   Installment @relation(fields: [installmentId], references: [id], onDelete: Cascade)
  amount        Decimal     @db.Decimal(12, 2)
  paymentDate   DateTime    @default(now())
  method        String      @default("CASH")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([installmentId])
  @@index([paymentDate])
}

model Investor {
  id           String       @id @default(cuid())
  name         String
  mobile       String?
  status       InvestorStatus @default(ACTIVE)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  plans        InstallmentPlan[]
  transactions InvestmentTransaction[]

  @@index([name])
  @@index([status])
}

model InvestmentAccount {
  id               String      @id @default("MAIN")
  availableBalance Decimal     @db.Decimal(12, 2) @default(0)
  totalDeposited   Decimal     @db.Decimal(12, 2) @default(0)
  totalCollected   Decimal     @db.Decimal(12, 2) @default(0)
  totalSpent       Decimal     @db.Decimal(12, 2) @default(0)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  transactions     InvestmentTransaction[]
}

model InvestmentTransaction {
  id         String                    @id @default(cuid())
  accountId  String                    @default("MAIN")
  account    InvestmentAccount         @relation(fields: [accountId], references: [id], onDelete: Cascade)
  investorId String?
  investor   Investor?                 @relation(fields: [investorId], references: [id], onDelete: SetNull)
  planId     String?
  plan       InstallmentPlan?          @relation(fields: [planId], references: [id], onDelete: SetNull)
  productId  String?
  product    Product?                  @relation(fields: [productId], references: [id], onDelete: SetNull)
  type       InvestmentTransactionType
  amount     Decimal                   @db.Decimal(12, 2)
  note       String?
  createdAt  DateTime                  @default(now())
  updatedAt  DateTime                  @updatedAt

  @@index([accountId])
  @@index([investorId])
  @@index([planId])
  @@index([productId])
  @@index([type])
  @@index([createdAt])
}
